diff --git a/src/components/dashboard/SshVaultPanel.tsx b/src/components/dashboard/SshVaultPanel.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..a7d68832614161fba457ce3bd2d599834c4e212b
--- /dev/null
+++ b/src/components/dashboard/SshVaultPanel.tsx
@@ -0,0 +1,237 @@
+"use client";
+
+import { useCallback, useEffect, useState } from "react";
+import type {
+  ApiError,
+  ApiResponse,
+  CreateProjectRequest,
+  CreateSessionRequest,
+  SessionInfo,
+  SshConfigInfo,
+} from "@/lib/types";
+
+interface SshVaultPanelProps {
+  onQuickConnect: (session: SessionInfo) => void;
+  onNewProject: (profileId: string) => void;
+  onEditProfile: (profileId: string) => void;
+  onAddProfile: () => void;
+}
+
+type BusyState = {
+  action: "quick-connect" | null;
+  profileId: string | null;
+  error: string | null;
+};
+
+export default function SshVaultPanel({
+  onQuickConnect,
+  onNewProject,
+  onEditProfile,
+  onAddProfile,
+}: SshVaultPanelProps) {
+  const [profiles, setProfiles] = useState<SshConfigInfo[]>([]);
+  const [loading, setLoading] = useState(true);
+  const [busy, setBusy] = useState<BusyState>({
+    action: null,
+    profileId: null,
+    error: null,
+  });
+
+  const loadProfiles = useCallback(async () => {
+    setLoading(true);
+    try {
+      const res = await fetch("/api/ssh-configs");
+      const json = (await res.json()) as ApiResponse<SshConfigInfo[]> | ApiError;
+      if ("data" in json) {
+        setProfiles(json.data);
+        setBusy((prev) => ({ ...prev, error: null }));
+      } else {
+        setBusy((prev) => ({ ...prev, error: json.error }));
+      }
+    } catch (err) {
+      setBusy((prev) => ({
+        ...prev,
+        error:
+          err instanceof Error ? err.message : "Failed to load SSH profiles",
+      }));
+    } finally {
+      setLoading(false);
+    }
+  }, []);
+
+  useEffect(() => {
+    void loadProfiles();
+  }, [loadProfiles]);
+
+  const handleQuickConnect = useCallback(
+    async (profile: SshConfigInfo) => {
+      setBusy({
+        action: "quick-connect",
+        profileId: profile.id,
+        error: null,
+      });
+
+      try {
+        const projectPayload: CreateProjectRequest = {
+          name: profile.label?.trim() || `${profile.username}@${profile.host}`,
+          type: profile.defaultDockerContainer ? "DOCKER" : "SSH",
+          color: "#f59e0b",
+          path:
+            profile.defaultPath?.trim() ||
+            (profile.defaultDockerContainer ? "/" : "~"),
+          sshConfigId: profile.id,
+          dockerContainer: profile.defaultDockerContainer ?? undefined,
+        };
+        const projectRes = await fetch("/api/projects", {
+          method: "POST",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify(projectPayload),
+        });
+        const projectJson = (await projectRes.json()) as
+          | ApiResponse<{ id: string }>
+          | ApiError;
+        if (!("data" in projectJson)) {
+          throw new Error(projectJson.error);
+        }
+
+        const sessionPayload: CreateSessionRequest = {
+          projectId: projectJson.data.id,
+          agentType: "terminal",
+          name: `${projectPayload.name} Quick Connect`,
+        };
+        const sessionRes = await fetch("/api/sessions", {
+          method: "POST",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify(sessionPayload),
+        });
+        const sessionJson = (await sessionRes.json()) as
+          | ApiResponse<SessionInfo>
+          | ApiError;
+        if (!("data" in sessionJson)) {
+          throw new Error(sessionJson.error);
+        }
+
+        onQuickConnect(sessionJson.data);
+      } catch (err) {
+        setBusy({
+          action: null,
+          profileId: null,
+          error:
+            err instanceof Error ? err.message : "Failed to open SSH session",
+        });
+        return;
+      }
+
+      setBusy({ action: null, profileId: null, error: null });
+    },
+    [onQuickConnect],
+  );
+
+  return (
+    <div className="rounded-lg border border-neutral-800 bg-neutral-900/60 p-3">
+      <div className="mb-3 flex items-center justify-between gap-3">
+        <div>
+          <div className="text-xs text-neutral-500">SSH Vault</div>
+          <div className="mt-1 text-sm text-neutral-300">
+            Reuse saved SSH profiles for quick sessions or new projects.
+          </div>
+        </div>
+        <div className="flex shrink-0 items-center gap-2">
+          <button
+            onClick={() => void loadProfiles()}
+            className="rounded border border-neutral-700 px-2 py-1 text-xs text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100"
+          >
+            Refresh
+          </button>
+          <button
+            onClick={onAddProfile}
+            className="rounded border border-neutral-700 px-2 py-1 text-xs text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100"
+          >
+            + Profile
+          </button>
+        </div>
+      </div>
+
+      {busy.error ? (
+        <div className="mb-3 rounded border border-red-900/60 bg-red-950/40 px-3 py-2 text-xs text-red-300">
+          {busy.error}
+        </div>
+      ) : null}
+
+      {loading ? (
+        <div className="rounded border border-neutral-800 bg-neutral-950/40 px-3 py-6 text-center text-sm text-neutral-500">
+          Loading SSH profiles...
+        </div>
+      ) : profiles.length === 0 ? (
+        <div className="rounded border border-dashed border-neutral-800 bg-neutral-950/40 px-3 py-8 text-center">
+          <div className="text-sm text-neutral-400">
+            No saved SSH profiles yet.
+          </div>
+          <button
+            onClick={onAddProfile}
+            className="mt-3 rounded border border-neutral-700 px-3 py-1.5 text-xs text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100"
+          >
+            Add your first profile
+          </button>
+        </div>
+      ) : (
+        <div className="space-y-2">
+          {profiles.map((profile) => {
+            const isConnecting =
+              busy.action === "quick-connect" && busy.profileId === profile.id;
+            return (
+              <div
+                key={profile.id}
+                className="flex flex-col gap-3 rounded border border-neutral-800 bg-neutral-950/40 p-3 lg:flex-row lg:items-center lg:justify-between"
+              >
+                <div className="min-w-0">
+                  <div className="flex flex-wrap items-center gap-2">
+                    <span className="text-sm font-medium text-neutral-100">
+                      {profile.label?.trim() || `${profile.username}@${profile.host}`}
+                    </span>
+                    <span className="rounded border border-neutral-700 px-1.5 py-0.5 text-[11px] text-neutral-400">
+                      {profile.defaultDockerContainer ? "Docker" : "SSH"}
+                    </span>
+                  </div>
+                  <div className="mt-1 text-xs text-neutral-400">
+                    {profile.username}@{profile.host}:{profile.port}
+                  </div>
+                  <div className="mt-1 text-xs text-neutral-500">
+                    Path {profile.defaultPath?.trim() || (profile.defaultDockerContainer ? "/" : "~")}
+                  </div>
+                  {profile.tags?.trim() ? (
+                    <div className="mt-1 text-xs text-neutral-500">
+                      Tags {profile.tags}
+                    </div>
+                  ) : null}
+                </div>
+
+                <div className="flex flex-wrap items-center gap-2">
+                  <button
+                    onClick={() => void handleQuickConnect(profile)}
+                    disabled={isConnecting}
+                    className="rounded border border-cyan-800 bg-cyan-950/40 px-3 py-1.5 text-xs text-cyan-200 hover:bg-cyan-900/40 disabled:cursor-not-allowed disabled:opacity-60"
+                  >
+                    {isConnecting ? "Connecting..." : "Quick Connect"}
+                  </button>
+                  <button
+                    onClick={() => onNewProject(profile.id)}
+                    className="rounded border border-neutral-700 px-3 py-1.5 text-xs text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100"
+                  >
+                    New Project
+                  </button>
+                  <button
+                    onClick={() => onEditProfile(profile.id)}
+                    className="rounded border border-neutral-700 px-3 py-1.5 text-xs text-neutral-300 hover:bg-neutral-800 hover:text-neutral-100"
+                  >
+                    Edit
+                  </button>
+                </div>
+              </div>
+            );
+          })}
+        </div>
+      )}
+    </div>
+  );
+}
