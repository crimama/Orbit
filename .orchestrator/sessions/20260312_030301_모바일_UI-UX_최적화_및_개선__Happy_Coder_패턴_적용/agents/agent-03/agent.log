 interface MobileLayoutProps {
   children: ReactNode;
 }
 
+const statusTimeFormatter = new Intl.DateTimeFormat("ko-KR", {
+  hour: "2-digit",
+  minute: "2-digit",
+  hour12: false,
+});
+
 export default function MobileLayout({ children }: MobileLayoutProps) {
