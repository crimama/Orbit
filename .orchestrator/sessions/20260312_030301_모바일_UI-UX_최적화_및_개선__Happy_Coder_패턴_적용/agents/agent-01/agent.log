+          style={{
+            paddingBottom: "calc(env(safe-area-inset-bottom, 0px) + 0.75rem)",
+          }}
+        >
+          <div className="grid grid-cols-2 gap-2 px-3 pt-2">
+            <button
+              onClick={() => {
+                if (selectedProject) {
+                  void handleCreateSelectedProjectSession();
+                  return;
+                }
+                void handleQuickCreateSession();
+              }}
+              disabled={creatingSession || projects.length === 0}
+              className="rounded-xl border border-neutral-700 bg-neutral-100 px-4 py-3 text-sm font-medium text-neutral-950 disabled:cursor-not-allowed disabled:opacity-40"
+            >
+              {creatingSession ? "Starting..." : "New Session"}
+            </button>
+            <button
+              onClick={() => void toggleYoloMode()}
+              className={`rounded-xl border px-4 py-3 text-sm font-medium transition-colors ${
+                yoloMode
+                  ? "border-red-500/60 bg-red-600/90 text-red-50"
+                  : "border-neutral-700 bg-neutral-900 text-neutral-200"
+              }`}
+            >
+              {yoloMode ? "YOLO ON" : "YOLO OFF"}
+            </button>
+          </div>
+        </div>
+      )}
+
+      <style jsx>{`
+        @keyframes dashboardFadeIn {
+          from {
+            opacity: 0;
+          }
+          to {
+            opacity: 1;
+          }
+        }
+      `}</style>
     </div>
   );
 }
