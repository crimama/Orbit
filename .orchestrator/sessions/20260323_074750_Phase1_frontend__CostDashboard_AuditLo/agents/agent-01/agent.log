+            비용 데이터를 불러오는 중입니다...
+          </div>
+        ) : null}
+
+        {!loading && !hasSessions ? (
+          <div className="mt-4 rounded-xl border border-dashed border-neutral-700 bg-neutral-950/50 px-4 py-8 text-center text-sm text-neutral-300">
+            토큰 추적 데이터가 아직 없습니다
+          </div>
+        ) : null}
+
+        {!loading && hasSessions ? (
