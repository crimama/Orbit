+                        dateTime={log.createdAt}
+                        className="shrink-0 text-[11px] text-neutral-500"
+                      >
+                        {formatTimeAgo(log.createdAt)}
+                      </time>
+                    </div>
+
+                    {log.detail ? (
+                      <p className="mt-1 line-clamp-2 text-xs text-neutral-400">
+                        {log.detail}
+                      </p>
+                    ) : null}
+                  </div>
+                </article>
+              );
+            })}
+          </div>
+        ) : null}
+      </div>
+    </section>
+  );
+}
