+  { key: "in_progress", label: "In Progress" },
+  { key: "done", label: "Done" },
+];
+
+function getColumnStatus(status: AgentTaskStatus): BoardColumnStatus {
+  if (status === "done") return "done";
+  if (status === "in_progress") return "in_progress";
+  return "pending";
