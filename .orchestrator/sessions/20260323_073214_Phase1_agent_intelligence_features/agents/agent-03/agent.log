+    return NextResponse.json({ data: newSession }, { status: 201 });
+  } catch (error) {
+    const message =
+      error instanceof Error ? error.message : "Failed to fork session";
+    return NextResponse.json({ error: message }, { status: 400 });
+  }
+}
