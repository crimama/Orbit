+  }
+
+  if (flattenedChildren.length === 1) {
+    return flattenedChildren[0];
+  }
+
+  return {
+    ...node,
+    children: flattenedChildren,
+    ratios: normalizeRatios(flattenedRatios, flattenedChildren.length),
+  };
