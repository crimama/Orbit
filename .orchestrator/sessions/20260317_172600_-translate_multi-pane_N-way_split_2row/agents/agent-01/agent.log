+      child.children.forEach((grandChild, grandIndex) => {
+        flattenedChildren.push(grandChild);
+        flattenedRatios.push(parentRatio * (child.ratios[grandIndex] ?? 0));
+      });
+      return;
+    }
+
+    flattenedChildren.push(child);
+    flattenedRatios.push(parentRatio);
+  });
