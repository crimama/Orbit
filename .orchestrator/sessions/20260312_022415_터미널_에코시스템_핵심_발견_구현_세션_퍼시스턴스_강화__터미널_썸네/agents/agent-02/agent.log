+            icon: "/icon-192x192.png",
+          });
+        }
+
+        if (existingIndex === -1) {
+          return [session, ...prev];
+        }
+
+        const next = [...prev];
+        next[existingIndex] = session;
+        return next;
+      });
+    };
+
+    socket.emit("dashboard-join");
+    socket.on("session-update", handleSessionUpdate);
+
