+        select: { sessionRef: true },
+      });
+      if (!current || current.sessionRef === claudeSessionId) return;
+
+      await prisma.agentSession.update({
+        where: { id: sessionId },
+        data: { sessionRef: claudeSessionId },
+      });
+    } catch {
+      // Best-effort capture only; session creation must not fail here.
+    }
+  }
