generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String         @id @default(uuid())
  name        String
  type        String         // "LOCAL" | "SSH" | "DOCKER"
  color       String         @default("#64748b")
  path        String
  sshConfigId String?
  dockerContainer String?
  adhoc       Boolean        @default(false)
  sshConfig   SshConfig?     @relation(fields: [sshConfigId], references: [id])
  sessions    AgentSession[]
  agents      ProjectAgent[]
  skills      Skill[]
  tasks       AgentTask[]
  fileLocks   FileLock[]
  harnessConfig ProjectHarnessConfig?
  workspaces  WorkspaceLayout[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model WorkspaceLayout {
  id           String   @id @default(uuid())
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  tree         String   // Serialized PaneNode JSON
  activePaneId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId, updatedAt])
}

model ProjectHarnessConfig {
  id              String   @id @default(uuid())
  projectId       String   @unique
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  enabled         Boolean  @default(true)
  provider        String   @default("oh-my-opencode") // "oh-my-opencode" | "claude-code" | "codex" | "terminal"
  profileName     String?
  autoApproveSafe Boolean  @default(false)
  maxParallel     Int      @default(3)
  config          String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProjectAgent {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  agentType   String   // "terminal" | "claude-code" | "codex" | "opencode"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, name])
}

model SshConfig {
  id            String      @id @default(uuid())
  label         String?
  tags          String?
  host          String
  port          Int         @default(22)
  username      String
  authMethod    String      // "key" or "password"
  keyPath       String?
  password      String?
  defaultPath   String?
  defaultDockerContainer String?
  proxyConfigId String?
  proxyConfig   SshConfig?  @relation("SshProxy", fields: [proxyConfigId], references: [id], onDelete: SetNull)
  proxiedBy     SshConfig[] @relation("SshProxy")
  projects      Project[]
  createdAt     DateTime    @default(now())
}

model AgentSession {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  name        String?  // 사용자 지정 세션 이름
  agentType   String   // "claude-code", "codex", "opencode", etc.
  sessionRef  String   // 에이전트 고유 세션 ID (resume용)
  lastContext String?  // 마지막 대화 맥락 요약
  status      String   @default("active") // "active", "paused", "terminated"
  chatMessages SessionChatMessage[]
  tokenLogs   SessionTokenLog[]
  checkpoints SessionCheckpoint[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SessionChatMessage {
  id        String       @id @default(uuid())
  sessionId String
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String       // "user" | "assistant"
  text      String
  position  Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([sessionId, position])
}

model Skill {
  id          String      @id @default(uuid())
  projectId   String?
  project     Project?    @relation(fields: [projectId], references: [id])
  name        String
  description String?
  mcpEndpoint String?
  config      String      @default("{}")
  posX        Float       @default(0)
  posY        Float       @default(0)
  nodeType    String      @default("default")
  edgesFrom   SkillEdge[] @relation("EdgeSource")
  edgesTo     SkillEdge[] @relation("EdgeTarget")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model SkillEdge {
  id       String @id @default(uuid())
  sourceId String
  targetId String
  source   Skill  @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target   Skill  @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
  label    String?
  animated Boolean @default(false)
  createdAt DateTime @default(now())

  @@unique([sourceId, targetId])
}

model InterceptorRule {
  id          String   @id @default(uuid())
  pattern     String
  description String
  severity    String   @default("block") // "warn" | "block" | "allow"
  riskTier    String   @default("WRITE") // "READ" | "WRITE" | "DESTRUCTIVE"
  riskScore   Int      @default(50)      // 0-100
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InterceptorConfig {
  id    String @id @default("singleton")
  mode  String @default("hybrid")  // "blacklist" | "allowlist" | "hybrid"
}

// --- Agent Intelligence: Token/Cost Tracking ---

model SessionTokenLog {
  id           String       @id @default(uuid())
  sessionId    String
  inputTokens  Int          @default(0)
  outputTokens Int          @default(0)
  estimatedCost Float       @default(0)
  model        String?
  session      AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  @@index([sessionId, createdAt])
}

// --- Audit Logging ---

model AuditLog {
  id        String   @id @default(uuid())
  sessionId String?
  projectId String?
  eventType String   // "interceptor_approve" | "interceptor_deny" | "session_create" | "session_terminate" | "ssh_connect" | "mode_change"
  action    String
  detail    String?  // JSON
  createdAt DateTime @default(now())
  @@index([sessionId, createdAt])
  @@index([projectId, createdAt])
  @@index([eventType, createdAt])
}

// --- Session Checkpointing & Forking ---

model SessionCheckpoint {
  id         String       @id @default(uuid())
  sessionId  String
  name       String
  cwd        String?
  scrollback Bytes?
  metadata   String?      // JSON: { gitBranch, env, etc. }
  session    AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  @@index([sessionId, createdAt])
}

// --- Multi-Agent Coordination ---

model AgentTask {
  id          String   @id @default(uuid())
  projectId   String
  sessionId   String?
  title       String
  description String?
  status      String   @default("pending") // "pending" | "in_progress" | "done" | "blocked"
  priority    Int      @default(0)
  assignee    String?
  deps        String?  // JSON array of task IDs
  files       String?  // JSON array of file paths
  result      String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([projectId, status])
}

model FileLock {
  id          String   @id @default(uuid())
  projectId   String
  filePath    String
  sessionId   String
  lineRange   String   @default("all")
  description String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  @@unique([projectId, filePath])
}
