{
  "name": "agent-orbit",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "orbit": "./bin/orbit.ts"
  },
  "scripts": {
    "dev": "rm -rf .next && tsx watch --tsconfig tsconfig.server.json server.ts",
    "dev:tailnet": "bash scripts/run-tailscale.sh",
    "build": "next build",
    "start": "NODE_ENV=production tsx --tsconfig tsconfig.server.json server.ts",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:typecheck": "node scripts/desktop-typecheck.mjs",
    "desktop:smoke": "node scripts/desktop-smoke.mjs",
    "desktop:package-smoke": "node scripts/desktop-package-smoke.mjs",
    "desktop:build": "npm run desktop:typecheck && npm run desktop:smoke && npm run desktop:package-smoke",
    "desktop:preview": "npm run build && npm run desktop:build"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/typography": "^0.5.19",
    "@uiw/react-codemirror": "^4.25.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "next": "14.2.35",
    "node-pty": "^1.1.0",
    "pako": "^2.1.0",
    "prisma": "^6.19.2",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/pako": "^2.0.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ssh2": "^1.15.5",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "main": "electron/bootstrap.cjs"
}
